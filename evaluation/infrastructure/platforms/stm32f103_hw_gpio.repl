// STM32F103 platform for hardware GPIO pulse-timing testing
// (DHT11, DHT22, HC-SR04, NEC IR, and similar single-pin 1-wire/PWM devices).
//
// GPIOB is the default Python peripheral for gpio_pulse_injector.
// evaluation.runtime.gpio_pulse_runner may move that Python peripheral to the
// task-selected GPIO bank (for example PA0/PA1) before each Renode run.
//
// The slave filename is patched by evaluation.runtime.gpio_pulse_runner to
// point at the per-stimulus rendered .py. The literal path below is a
// placeholder so this .repl stays loadable on its own for debugging.

fsmcBank1: Memory.MappedMemory @ sysbus 0x60000000
    size: 0x10000000

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x10000000

flash: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x20000000

usart1: UART.STM32_UART @ sysbus <0x40013800, +0x100>
    -> nvic@37

usart2: UART.STM32_UART @ sysbus <0x40004400, +0x100>
    -> nvic@38

usart3: UART.STM32_UART @ sysbus <0x40004800, +0x100>
    -> nvic@39

nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xF0
    systickFrequency: 72000000
    IRQ -> cpu@0

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic

i2c2: I2C.STM32F4_I2C @ sysbus 0x40005800
    EventInterrupt -> nvic@33
    ErrorInterrupt -> nvic@34

exti: IRQControllers.STM32F4_EXTI @ sysbus 0x40010400
    numberOfOutputLines: 19
    [0-4] -> nvic@[6-10]
    [5-9] -> nvicInput23@[0-4]
    [10-15] -> nvicInput40@[0-5]

nvicInput23: Miscellaneous.CombinedInput @ none
    numberOfInputs: 5
    -> nvic@23

nvicInput40: Miscellaneous.CombinedInput @ none
    numberOfInputs: 6
    -> nvic@40

gpioPortA: GPIOPort.STM32F1GPIOPort @ sysbus <0x40010800, +0x400>
    [0-15] -> exti@[0-15]

// GPIOB: Python peripheral emulating pulse-timing injector on one pin.
// Base 0x40010C00, 0x400 region covers CRL/CRH/IDR/ODR/BSRR/BRR/LCKR/AFR.
gpioPortB: Python.PythonPeripheral @ sysbus 0x40010C00
    size: 0x400
    initable: true
    filename: "evaluation/infrastructure/slaves/gpio_pulse_injector.py"

gpioPortC: GPIOPort.STM32F1GPIOPort @ sysbus <0x40011000, +0x400>
    [0-15] -> exti@[0-15]

rcc: Python.PythonPeripheral @ sysbus 0x40021000
    size: 0x400
    initable: true
    filename: "evaluation/renode_tester/models/stm32f1_rcc.py"

bitband_rcc: Python.PythonPeripheral @ sysbus 0x42420000
    size: 0x8000
    initable: true
    filename: "evaluation/renode_tester/models/stm32f1_rcc_bitband.py"

flash_acr: Memory.MappedMemory @ sysbus 0x40022000
    size: 0x400

// TIM2 for system tick (IRQ 28)
timer2: Timers.STM32_Timer @ sysbus <0x40000000, +0x400>
    frequency: 72000000
    initialLimit: 0xFFFF
    -> nvic@28

// PWR controller (init-only)
pwr: Memory.MappedMemory @ sysbus 0x40007000
    size: 0x400

// DWT (cycle counter) at 0xE0001000
dwt: Memory.MappedMemory @ sysbus 0xE0001000
    size: 0x400

// DBGMCU at 0xE0042000
dbgmcu: Memory.MappedMemory @ sysbus 0xE0042000
    size: 0x400

sysbus:
    init:
        Tag <0x40022000, 0x40022003> "FLASH_ACR" 0x00000032
        Tag <0xE0042000, 0xE0042003> "DBGMCU_IDCODE" 0x20036410
        LoadSVD @https://raw.githubusercontent.com/cmsis-svd/cmsis-svd-data/main/data/STMicro/STM32F103xx.svd
