{
  "_meta": {
    "description": "Centralised tunables for RTOS context extraction.",
    "owner": "drivergen.rtos"
  },
  "indexer": {
    "max_file_size_bytes": 500000,
    "exported_symbols_per_file_cap": 80,
    "header_summary_max_chars": 200,
    "parser_workers": 4
  },
  "candidate_ranker": {
    "max_candidate_files_per_slot": 12,
    "llm_rerank_candidate_files_per_slot": 128,
    "max_candidate_symbols_per_slot": 30,
    "max_candidate_symbols_per_task": 300,
    "nearby_text_max_chars": 300,
    "llm_binder_topk": 15
  },
  "llm_budget": {
    "max_calls_per_task_default": 60,
    "max_calls_per_task_exhaustive": 90,
    "max_input_tokens_per_task_default": 320000,
    "max_output_tokens_per_task_default": 80000,
    "per_call": {
      "directory_router": {
        "input_tokens": 6000,
        "output_tokens": 700,
        "max_per_round": 1,
        "max_per_task": 4
      },
      "file_selector": {
        "input_tokens": 16000,
        "output_tokens": 1400,
        "max_per_round": 1,
        "max_per_task": 4
      },
      "symbol_binder": {
        "input_tokens_per_slot": 4000,
        "output_tokens_per_slot": 700,
        "max_slots_per_call": 1
      },
      "gap_diagnoser": {
        "input_tokens": 2000,
        "output_tokens": 500,
        "max_per_task": 2
      },
      "transaction_translator": {
        "input_tokens": 3000,
        "output_tokens": 800,
        "max_per_task": 1
      }
    }
  },
  "scoring": {
    "bus_keyword_weight": 2.0,
    "path_token_intent_weight": 3.0,
    "preferred_root_role_bonus": 1.5,
    "demo_path_penalty": 0.5,
    "test_path_penalty": 0.5,
    "max_dirs_per_slot": 8,
    "llm_rerank_candidate_dirs_per_slot": 64
  },
  "binder": {
    "top1_min_score": 5.0,
    "top1_to_top2_ratio": 1.5,
    "confidence_score_cap": 30.0
  },
  "cache": {
    "indexer_version": "1.0",
    "artifact_version": "1.0"
  }
}
