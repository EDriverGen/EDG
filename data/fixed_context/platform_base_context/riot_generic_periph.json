{
  "platform_id": "riot_generic_periph",
  "board": "nucleo-f103rb",
  "board_alias": "riot_f103rb",
  "rtos": "riot",
  "rtos_bundle": "riot",
  "integration": "riot_periph_driver_api",
  "integration_style": "riot_periph_plus_ztimer",
  "mcu_family": "stm32f1",
  "mcu": "stm32f103rb",
  "capabilities": {
    "connection_types": [
      "i2c",
      "spi",
      "gpio_timing",
      "uart_polling"
    ],
    "available_instances": {
      "i2c": [
        "I2C_DEV(0)"
      ],
      "spi": [
        "SPI_DEV(0)"
      ],
      "gpio_timing": [
        "default_gpio_slot"
      ],
      "uart_polling": [
        "UART_DEV(1)"
      ]
    },
    "timing": [
      "millisecond_delay",
      "microsecond_delay"
    ],
    "gpio": "available",
    "irq": "optional",
    "dma": "absent"
  },
  "notes": [
    "This platform targets RIOT's nucleo-f103rb board while using the portable periph/i2c.h, periph/spi.h, and periph/gpio.h APIs.",
    "I2C uses integer i2c_t with acquire/release bus locking and read_regs/write_regs register access.",
    "SPI uses periph/spi.h with spi_t, spi_cs_t, spi_acquire/spi_release and spi_transfer_bytes.",
    "UART fixed-frame sensors use periph/uart.h with UART_DEV(1).",
    "Delays use ztimer_sleep(ZTIMER_MSEC, ms) (preferred over legacy xtimer)."
  ],
  "evidence": [
    "DriverGen/data/rtos/riot/drivers/include/periph/i2c.h",
    "DriverGen/data/rtos/riot/drivers/include/periph/spi.h",
    "DriverGen/data/rtos/riot/drivers/include/periph/uart.h",
    "DriverGen/data/rtos/riot/drivers/include/periph/gpio.h",
    "DriverGen/data/rtos/riot/drivers/bh1750fvi/bh1750fvi.c"
  ]
}
