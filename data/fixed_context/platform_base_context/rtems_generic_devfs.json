{
  "platform_id": "rtems_generic_devfs",
  "board": "generic_devfs",
  "board_alias": "rtems_devfs",
  "rtos": "rtems",
  "rtos_bundle": "rtems",
  "integration": "rtems_devfs_bus_api",
  "integration_style": "rtems_posix_devfs_driver_api",
  "mcu_family": "stm32f1",
  "mcu": "stm32f103rb",
  "capabilities": {
    "connection_types": [
      "i2c",
      "spi",
      "uart_polling",
      "gpio_timing"
    ],
    "available_instances": {
      "i2c": [
        "/dev/i2c-0"
      ],
      "spi": [
        "/dev/spi-0"
      ],
      "uart_polling": [
        "/dev/ttyS0"
      ],
      "gpio_timing": [
        "default_gpio_slot"
      ]
    },
    "timing": [
      "rtems_task_wake_after",
      "RTEMS_MILLISECONDS_TO_TICKS"
    ],
    "gpio": "bsp_dependent",
    "irq": "optional",
    "dma": "absent"
  },
  "notes": [
    "RTEMS provides I2C/SPI frameworks under cpukit/dev and Linux-compatible userspace headers under cpukit/include/linux.",
    "The initial DriverGen target uses generic devfs-style bus nodes; concrete APIs must be extracted from the RTEMS source tree."
  ],
  "evidence": [
    "DriverGen/data/rtos/rtems/cpukit/include/dev/i2c/i2c.h",
    "DriverGen/data/rtos/rtems/cpukit/include/linux/i2c.h",
    "DriverGen/data/rtos/rtems/cpukit/include/linux/i2c-dev.h",
    "DriverGen/data/rtos/rtems/cpukit/include/dev/spi/spi.h",
    "DriverGen/data/rtos/rtems/cpukit/include/linux/spi/spidev.h",
    "DriverGen/data/references/*/rtems/*_ref.h"
  ]
}
