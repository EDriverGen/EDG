  "notes": [
    "Apache Mynewt includes kernel/os, hw/hal, hw/mcu, hw/bsp, hw/drivers, hw/sensor and hw/util in one repository.",
    "Device drivers should prefer public HAL headers such as hal/hal_i2c.h, hal/hal_spi.h, hal/hal_gpio.h and OS helpers from os/os_time.h."
  ],
  "evidence": [
    "DriverGen/data/rtos/apache-mynewt/kernel/os/include/os/os_time.h",
    "DriverGen/data/rtos/apache-mynewt/hw/hal/include/hal/hal_i2c.h",
    "DriverGen/data/rtos/apache-mynewt/hw/hal/include/hal/hal_spi.h",
    "DriverGen/data/rtos/apache-mynewt/hw/hal/include/hal/hal_uart.h",
    "DriverGen/data/rtos/apache-mynewt/hw/util/i2cn/include/i2cn/i2cn.h",
    "DriverGen/data/references/*/apache-mynewt/*_ref.h"
  ]
}
