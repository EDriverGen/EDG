					"command": [
						255,
						1,
						134,
						0,
						0,
						0,
						0,
						0,
						121
					],
					"response": [
						255,
						134,
						1,
						194,
						62,
						64,
						0,
						0,
						57
					]
				}
			],
			"note": "Sensor warm-up phase: status byte has bit 0x40 set. ppm still readable.",
			"expected": {
				"raw_alt": [
					450
				]
			}
		}
	]
}
