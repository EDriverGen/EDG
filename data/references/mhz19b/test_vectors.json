					"response": [
						255,
						134,
						7,
						208,
						67,
						0,
						0,
						0,
						96
					]
				}
			],
			"note": "Strongly elevated: 2000 ppm. Tests 2-byte decode at 0x07D0.",
			"expected": {
				"raw_alt": [
					2000
				]
			}
		},
		{
			"name": "co2_5000ppm_full_range",
			"uart_pairs": [
				{
					"command": [
						255,
						1,
						134,
						0,
						0,
						0,
						0,
						0,
						121
					],
					"response": [
						255,
						134,
						19,
						136,
						68,
						0,
						0,
						0,
						155
					]
				}
			],
			"note": "Max sensor range 5000 ppm. Tests near-full-scale value.",
			"expected": {
				"raw_alt": [
					5000
				]
			}
		},
		{
			"name": "co2_zero_calibration_boundary",
			"uart_pairs": [
				{
					"command": [
						255,
						1,
						134,
						0,
						0,
						0,
						0,
