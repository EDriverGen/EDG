{
	"device_id": "emc1413",
	"description": "EMC1413 Triple Temperature Sensor — Standard Test Vectors for Renode I2C Emulation",
	"i2c_address_7bit": "0x4C",
	"register_map": {
		"0xFE": {
			"name": "manufacturer_id",
			"bytes": [
				"0x5D"
			],
			"description": "Manufacturer ID = 0x5D (SMSC)"
		},
		"0xFD": {
			"name": "product_id",
			"bytes": [
				"0x21"
			],
			"description": "Product ID = 0x21 (EMC1413)"
		},
		"0xFF": {
			"name": "revision",
			"bytes": [
				"0x04"
			],
			"description": "Revision register"
		},
		"0x02": {
			"name": "status",
			"bytes": [
				"0x00"
			],
			"description": "Status register"
		},
		"0x03": {
			"name": "config",
			"bytes": [
				"0x00"
			],
			"description": "Configuration register"
		},
		"0x04": {
			"name": "conversion_rate",
			"bytes": [
				"0x08"
			],
			"description": "Conversion rate register"
		},
		"0x00": {
			"name": "int_temp_high",
			"bytes": [
				"0x19"
			],
			"description": "Internal temperature high byte = 25 (0x19)"
		},
		"0x29": {
			"name": "int_temp_low",
			"bytes": [
				"0x00"
			],
			"description": "Internal temperature low byte (fraction bits)"
		},
		"0x01": {
			"name": "ext1_temp_high",
			"bytes": [
				"0x19"
			],
			"description": "External diode 1 temperature high byte = 25"
		},
		"0x10": {
			"name": "ext1_temp_low",
			"bytes": [
				"0x80"
			],
			"description": "External diode 1 temperature low byte = 0.5 C"
		},
		"0x23": {
			"name": "ext2_temp_high",
			"bytes": [
				"0x1A"
			],
			"description": "External diode 2 temperature high byte = 26"
		},
		"0x24": {
			"name": "ext2_temp_low",
			"bytes": [
				"0x40"
			],
			"description": "External diode 2 temperature low byte = 0.25 C"
		}
	},
	"test_flow": {
		"type": "auto_gen",
		"steps": [
			{
				"action": "init",
				"description": "Call emc1413_init(). Reads manufacturer/product ID. Expect return 0."
			},
			{
				"action": "read",
				"description": "Call emc1413_read_temp(&int_temp_mc, &ext1_mc, &ext2_mc). Reads temp registers. Expect return 0."
			},
			{
				"action": "value_check",
				"description": "Verify int_temp_mc in expected range."
			}
		]
	},
	"physical_range": {
		"default": {
			"raw_value_description": "Internal temperature in millidegrees C. 0x19,0x00 → 25.0 C → 25000 mC.",
			"min": 24000,
			"max": 26000
		}
	},
	"assertions": {
		"count": 3,
		"details": [
			{
				"id": "init",
				"description": "Init returns 0"
			},
			{
				"id": "read_err",
				"description": "Read returns 0"
			},
			{
				"id": "value_range",
				"description": "int_temp_mc in [24000, 26000]"
			}
		]
	},
	"required_writes": [
		{
			"addr": "0x4C",
			"any_of": [
				[
					"0x00"
				],
				[
					"0x01"
				],
				[
					"0x23"
				]
			],
			"description": "Register pointer write for high byte of temperature: 0x00 (internal), 0x01 (ext1), or 0x23 (ext2)."
		},
		{
			"addr": "0x4C",
			"any_of": [
				[
					"0x29"
				],
				[
					"0x10"
				],
				[
					"0x24"
				]
			],
			"description": "Register pointer write for low byte: 0x29 (internal), 0x10 (ext1), or 0x24 (ext2)."
		}
	],
	"harness": {
		"raw_decl": "int32_t raw = 0;",
		"read_raw": "emc1413_read_temperature(&g_dev, EMC1413_CH_INTERNAL, &raw)",
		"pre_read_c": "err = emc1413_probe(&g_dev);\nif (err != RT_EOK) { hw_uart2_puts(\"ERROR: probe failed\\r\\n\"); goto done; }"
	},
