{
	"device_id": "tmp421",
	"description": "TMP421 Dual Remote/Local Temperature Sensor — Standard Test Vectors for Renode I2C Emulation",
	"i2c_address_7bit": "0x2A",
	"register_map": {
		"0xFE": {
			"name": "manufacturer_id",
			"bytes": ["0x55"],
			"description": "Manufacturer ID = 0x55 (TI)"
		},
		"0xFF": {
			"name": "device_id",
			"bytes": ["0x21"],
			"description": "Device ID = 0x21 (TMP421)"
		},
		"0x08": {
			"name": "status",
			"bytes": ["0x00"],
			"description": "Status register"
		},
		"0x09": {
			"name": "config1",
			"bytes": ["0x00"],
			"description": "Configuration register 1"
		},
		"0x0A": {
			"name": "config2",
			"bytes": ["0x00"],
			"description": "Configuration register 2"
		},
		"0x00": {
			"name": "local_temp_high",
			"bytes": ["0x19"],
			"description": "Local temperature high byte = 25 (0x19)"
		},
		"0x10": {
			"name": "local_temp_low",
			"bytes": ["0x00"],
			"description": "Local temperature low byte = 0"
		},
		"0x01": {
			"name": "remote_temp_high",
			"bytes": ["0x1A"],
			"description": "Remote temperature high byte = 26"
		},
		"0x11": {
			"name": "remote_temp_low",
			"bytes": ["0x80"],
			"description": "Remote temperature low byte = 0.5 C"
		}
	},
	"test_flow": {
		"type": "auto_gen",
		"steps": [
			{
				"action": "init",
				"description": "Call tmp421_init(). Reads manufacturer/device ID. Expect return 0."
			},
			{
				"action": "read",
				"description": "Call tmp421_read_temp(&local_mc, &remote_mc). Reads temperature registers. Expect return 0."
			},
			{
				"action": "value_check",
				"description": "Verify local_mc in expected range."
			}
		]
	},
	"physical_range": {
		"default": {
			"raw_value_description": "Local temperature in millidegrees C. 0x19,0x00 → 25.0 C → 25000 mC.",
			"min": 24000,
			"max": 26000
		}
	},
	"assertions": {
		"count": 3,
		"details": [
			{
				"id": "init",
				"description": "Init returns 0"
			},
			{
				"id": "read_err",
				"description": "Read returns 0"
			},
			{
				"id": "value_range",
				"description": "local_mc in [24000, 26000]"
			}
		]
	},
	"required_writes": [
		{
			"addr": "0x2A",
			"any_of": [["0x00"], ["0x01"]],
			"description": "Register pointer write for temperature HI byte: 0x00 (local) or 0x01 (remote)."
		},
		{
			"addr": "0x2A",
			"any_of": [["0x10"], ["0x11"]],
			"description": "Register pointer write for temperature LO byte: 0x10 (local) or 0x11 (remote)."
		}
	],
	"harness": {
		"raw_decl": "int32_t raw = 0;",
		"read_raw": "tmp421_read_local_temp(&g_dev, &raw)",
		"pre_read_c": "err = tmp421_probe(&g_dev);\nif (err != RT_EOK) { hw_uart2_puts(\"ERROR: probe failed\\r\\n\"); goto done; }"
	},
	"runtime_tests": [
		{
			"name": "local_25c_remote_26_5c",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [25],
				"16": [0],
				"1": [26],
				"17": [128]
			},
			"expected": {
				"raw": 25000,
				"raw_alt": [25]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Manufacturer 0xFE=0x55=85, device 0xFF=0x21=33. Local temp 0x19=25.0°C. raw_alt covers drivers returning °C (25)."
		},
		{
			"name": "local_0c_remote_0c_zero_point",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [0],
				"16": [0],
				"1": [0],
				"17": [0]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Both channels 0 C. Zero-point baseline.",
			"expected": {
				"raw": 0,
				"raw_alt": [0]
			}
		},
		{
			"name": "local_neg25c_remote_neg40c_negative",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [231],
				"16": [0],
				"1": [216],
				"17": [0]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Local -25 C, Remote -40 C (cold storage).",
			"expected": {
				"raw": -25000,
				"raw_alt": [-25, 231]
			}
		},
		{
			"name": "local_100c_remote_100c_high",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [100],
				"16": [0],
				"1": [100],
				"17": [0]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Both channels 100 C (boiling point).",
			"expected": {
				"raw": 100000,
				"raw_alt": [100]
			}
		},
		{
			"name": "local_25c_fractional_0_0625",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [25],
				"16": [16],
				"1": [25],
				"17": [0]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Local 25 + 0.0625 C (LSB bit highest). Minimum resolution step.",
			"expected": {
				"raw": 25062,
				"raw_alt": [25, 25062]
			}
		},
		{
			"name": "local_150c_remote_neg40c_extremes",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [150],
				"16": [0],
				"1": [216],
				"17": [0]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Local 150 C (datasheet max) + Remote -40 C (min). Full-range asymmetric extremes. Basic range mode treats 0x96 HI as int8 = -106 C (-106000 mC); extended range mode would decode 150 C. Reference driver uses basic range.",
			"expected": {
				"raw": 150000,
				"raw_alt": [150, -106000, -106]
			}
		},
		{
			"name": "local_25c_remote_85c_typical_chip_hotspot",
			"renode_regs": {
				"254": [85],
				"255": [33],
				"8": [0],
				"9": [0],
				"10": [0],
				"0": [25],
				"16": [0],
				"1": [85],
				"17": [128]
			},
			"tolerance": {
				"raw": 500
			},
			"note": "Local 25 C ambient, Remote 85.5 C (CPU die hotspot). Typical monitoring scenario.",
			"expected": {
				"raw": 25000,
				"raw_alt": [25]
			}
		}
	]
}
