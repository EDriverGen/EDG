{
  "device_id": "bme280",
  "description": "BME280 Temperature/Pressure/Humidity Sensor — Standard Test Vectors for Renode I2C Emulation",
  "i2c_address_7bit": "0x76",
  "harness": {
    "_comment": "BME280 measurement requires: probe + read_calibration + read (all three). Expose temperature (×100 °C scaled down to ×10) through `raw` for generic harness.",
    "read_decl": "int32_t t_mc = 0; uint32_t p_pa = 0; uint32_t h_mp = 0;",
    "pre_read_c": "if (bme280_probe(&g_dev) != 0 || bme280_read_calibration(&g_dev) != 0) { err = -1; goto done; }",
    "read_raw": "bme280_read(&g_dev, &t_mc, &p_pa, &h_mp); raw = (rt_uint16_t)(t_mc / 10)"
  },
  "register_map": {
    "0xD0": {
      "name": "chip_id",
      "bytes": [
        "0x60"
      ],
      "description": "Chip ID = 0x60 (BME280)"
    },
    "0x88": {
      "name": "calib_tp",
      "bytes": [
        "0x70",
        "0x6B",
        "0x43",
        "0x67",
        "0x18",
        "0xFC",
        "0x7D",
        "0x8E",
        "0x43",
        "0xD6",
        "0xD0",
        "0x0B",
        "0x27",
        "0x0B",
        "0x8C",
        "0x00",
        "0xF9",
        "0xFF",
        "0x8C",
        "0x3C",
        "0xF8",
        "0xC6",
        "0x70",
        "0x17",
        "0x00",
        "0x00"
      ],
      "description": "Temperature & pressure calibration (26 bytes: dig_T1..dig_P9)"
    },
    "0xA1": {
      "name": "calib_h1",
      "bytes": [
        "0x4B"
      ],
      "description": "Humidity calibration part 1 (dig_H1)"
    },
    "0xE1": {
      "name": "calib_h2_6",
      "bytes": [
        "0x72",
        "0x01",
        "0x00",
        "0x13",
        "0x29",
        "0x03",
        "0x1E"
      ],
      "description": "Humidity calibration part 2 (dig_H2..dig_H6, 7 bytes)"
    },
    "0xF7": {
      "name": "raw_data",
      "bytes": [
        "0x51",
        "0x40",
        "0x00",
        "0x7E",
        "0xED",
        "0x00",
        "0x6D",
        "0x60"
      ],
      "description": "Raw pressure (3B) + temp (3B) + humidity (2B), 8 bytes total"
    },
    "0xF2": {
      "name": "ctrl_hum",
      "bytes": [
        "0x00"
      ],
      "description": "Humidity oversampling control"
    },
    "0xF3": {
      "name": "status",
      "bytes": [
        "0x00"
      ],
      "description": "Status: 0x00 = not measuring, not updating"
    },
    "0xF4": {
      "name": "ctrl_meas",
      "bytes": [
        "0x00"
      ],
      "description": "Measurement control"
    }
  },
  "test_flow": {
    "type": "custom",
    "steps": [
      {
        "action": "init",
        "description": "Call bme280_init(). Reads chip ID (0x60). Expect return 0."
      },
      {
        "action": "read_calibration",
        "description": "Call bme280_read_calibration(). Reads 26+1+7 bytes of cal data. Expect return 0."
      },
      {
        "action": "read",
        "description": "Call bme280_read(&temp_mc, &press_pa, &hum_mp). Waits for status ready. Expect return 0."
      },
      {
        "action": "value_check",
        "description": "Verify temp_mc in expected range."
      }
    ]
  },
  "physical_range": {
    "default": {
      "raw_value_description": "Temperature in millidegrees C (temp_mc). Result ~25080 from compensation algorithm.",
      "min": 24000,
      "max": 26000
    }
  },
  "assertions": {
    "count": 4,
    "details": [
      {
        "id": "init",
        "description": "Init returns 0"
      },
      {
        "id": "calib",
        "description": "Read calibration returns 0"
      },
      {
        "id": "read_err",
        "description": "Read returns 0"
      },
      {
        "id": "value_range",
        "description": "temp_mc in [24000, 26000]"
      }
    ]
  },
  "required_writes": [
    {
      "addr": "0x76",
      "description": "Chip-ID read preamble: write register pointer 0xD0 to read chip ID (0x60).",
      "any_of": [
        [
          "0xD0"
        ]
      ]
    },
    {
      "addr": "0x76",
      "description": "Calibration burst read: write pointer 0x88 (dig_T1..dig_P9, 26 bytes).",
      "any_of": [
        [
          "0x88"
        ]
      ]
    },
    {
      "addr": "0x76",
      "description": "ctrl_meas (0xF4) must be written with non-zero mode bits (1=forced, 3=normal); sensor stays in sleep otherwise and F7 stays stale.",
      "any_of": [
        [
          "0xF4",
          "0x25"
        ],
        [
          "0xF4",
          "0x26"
        ],
        [
          "0xF4",
          "0x27"
        ],
        [
          "0xF4",
          "0x21"
        ],
        [
          "0xF4",
          "0x22"
        ],
        [
          "0xF4",
          "0x23"
        ],
        [
          "0xF4",
          "0x29"
        ],
        [
          "0xF4",
          "0x2D"
        ],
        [
          "0xF4",
          "0x2F"
        ],
        [
          "0xF4",
          "0xB7"
        ],
        [
          "0xF4",
          "0xBF"
        ],
        [
          "0xF4",
          "0x57"
        ],
        [
          "0xF4",
          "0xA5"
        ],
        [
          "0xF4",
          "0xA7"
        ]
      ]
    },
    {
      "addr": "0x76",
      "description": "Raw data burst read: write pointer 0xF7 (press/temp/hum 8 bytes from F7..FE).",
      "any_of": [
        [
          "0xF7"
        ]
      ]
    }
  ],
