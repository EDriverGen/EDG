{
	"device_id": "mcp3008",
	"description": "MCP3008 8-Channel 10-bit SPI ADC — Standard Test Vectors for Renode SPI Emulation",
	"bus_type": "spi",
	"spi_config": {
		"mode": 0,
		"max_freq_hz": 3600000,
		"cs_active_low": true
	},
	"protocol": {
		"transaction_bytes": 3,
		"byte0_tx": "0x01 (start bit)",
		"byte1_tx": "SGL/DIFF(bit7) | channel(bits6:4) | don't care(bits3:0)",
		"byte1_rx": "null bit(bit2) | D9(bit1) | D8(bit0)",
		"byte2_rx": "D7:D0"
	},
	"test_flow": {
		"type": "auto_gen",
		"steps": [
			{
				"action": "init",
				"description": "Call mcp3008_init(). Configure SPI bus. Returns 0."
			},
			{
				"action": "read_channel",
				"description": "Call mcp3008_read_channel(0). Read channel 0 single-ended."
			},
			{
				"action": "read_multiple",
				"description": "Read channels 0-7 sequentially, verify all return valid 10-bit values."
			},
			{
				"action": "voltage_conversion",
				"description": "Convert raw to millivolts: voltage_mv = raw * vref_mv / 1023."
			},
			{
				"action": "value_check",
				"description": "Verify channel 0 raw ≈ 512, channel 2 raw ≈ 768."
			}
		]
	},
	"simulated_channels": {
		"ch0": {
			"raw": 512,
			"description": "Mid-scale, ~1.65V @ 3.3V Vref"
		},
		"ch1": {
			"raw": 256,
			"description": "Quarter-scale, ~0.82V @ 3.3V Vref"
		},
		"ch2": {
			"raw": 768,
			"description": "Three-quarter scale, ~2.47V @ 3.3V Vref"
		},
		"ch3": {
			"raw": 100,
			"description": "Low value, ~0.32V"
		},
		"ch4": {
			"raw": 900,
			"description": "High value, ~2.90V"
		},
		"ch5": {
			"raw": 450,
			"description": "~1.45V"
		},
		"ch6": {
			"raw": 600,
			"description": "~1.94V"
		},
		"ch7": {
			"raw": 330,
			"description": "~1.07V"
		}
	},
	"expected_output": {
		"channel_0": {
			"raw": {
				"min": 500,
				"max": 524
			},
			"voltage_mv_3v3": {
				"min": 1600,
				"max": 1700
			},
			"description": "Channel 0: mid-scale ADC value"
		},
		"channel_2": {
			"raw": {
				"min": 756,
				"max": 780
			},
			"voltage_mv_3v3": {
				"min": 2430,
				"max": 2520
			},
			"description": "Channel 2: three-quarter scale"
		},
		"all_channels": {
			"min": 0,
			"max": 1023,
			"description": "All channels must return 10-bit values [0, 1023]"
		}
	},
	"rtos_overrides": {
		"rtthread": {
			"init_call": "mcp3008_init(&g_dev, \"spi10\")"
		},
		"freertos": {
			"init_call": "mcp3008_init(&g_dev, &hspi1, CS_PORT, CS_PIN)"
		},
		"zephyr": {
			"init_call": "mcp3008_init(&g_dev, spi_dev, &cs_gpio)"
		}
	},
	"assertions": {
		"count": 5,
		"details": [
			{
				"id": "init",
				"description": "Init returns 0"
			},
			{
				"id": "read_ch0",
				"description": "Channel 0 read returns 0"
			},
			{
				"id": "ch0_range",
				"description": "Channel 0 raw in [500, 524]"
			},
			{
				"id": "ch2_range",
				"description": "Channel 2 raw in [756, 780]"
			},
			{
				"id": "all_valid",
				"description": "All 8 channels return values in [0, 1023]"
			}
		]
	},
	"spi_proto": "mcp3008",
	"runtime_tests": [
		{
			"name": "ch0_half_scale",
			"spi_regs": {
				"0": [2, 0]
			},
			"note": "Channel 0 reads 512 (Vref/2). Single-ended mode.",
			"expected": {
				"raw_alt": [512]
			}
		},
		{
			"name": "quarter_scale_256",
			"spi_regs": {
				"0": [1, 0]
			},
			"note": "Channel 0 reads 256 (~Vref/4).",
			"expected": {
				"raw_alt": [256]
			}
		},
		{
			"name": "full_scale_1023",
			"spi_regs": {
				"0": [3, 255]
			},
			"note": "Channel 0 at max 10-bit value 1023.",
			"expected": {
				"raw_alt": [1023]
			}
		},
		{
			"name": "ch0_zero",
			"spi_regs": {
				"0": [0, 0]
			},
			"note": "Channel 0 grounded: ADC reads 0.",
			"expected": {
				"raw_alt": [0]
			}
		},
		{
			"name": "near_full_1000",
			"spi_regs": {
				"0": [3, 232]
			},
			"note": "Channel 0 near full scale.",
			"expected": {
				"raw_alt": [1000]
			}
		},
		{
			"name": "third_341",
			"spi_regs": {
				"0": [1, 85]
			},
			"note": "Channel 0 at ~1/3 Vref. Tests non-power-of-2 value.",
			"expected": {
				"raw_alt": [341]
			}
		},
		{
			"name": "boundary_low_1",
			"spi_regs": {
				"0": [0, 1]
			},
			"note": "Channel 0 at LSB+1. Tests boundary near zero.",
			"expected": {
				"raw_alt": [1]
			}
		}
	]
}
