# Local secrets — never commit API keys
.secrets/*
!.secrets/README.md
!.secrets/.gitkeep

# Python build / cache artefacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor / OS detritus
.DS_Store
Thumbs.db

# Pipeline artefacts that don't belong in version control
runs/*
!runs/.gitkeep
tmp/
scratch/
.codex_tmp/
smoke_runs/
